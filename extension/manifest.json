{
  "manifest_version": 2,
  "name": "WhatsApp Web Audit Local",
  "version": "1.0.0",
  "description": "Detecta mensajes nuevos en WhatsApp Web y los envia a un backend local.",
  "permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost:43177/*",
    "http://127.0.0.1:43177/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "whatsapp-web-audit-local@example.com"
    }
  }
}
